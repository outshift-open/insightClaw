+# Optional: import SRE triage OpenClaw agent workspaces from a sibling repo.
+ARG OPENCLAW_REPO_DIR=sre-triage/openclaw
+COPY ${OPENCLAW_REPO_DIR}/services/db_api/ /sandbox/.openclaw-data/services/db_api/
+RUN python3 -m pip install --no-cache-dir --break-system-packages \
+    -r /sandbox/.openclaw-data/services/db_api/requirements.txt
+COPY ${OPENCLAW_REPO_DIR}/workspaces/ /sandbox/.openclaw-data/workspaces/
+COPY ${OPENCLAW_REPO_DIR}/workspaces/sre/ /sandbox/.openclaw-data/agents/sre/agent/
+COPY ${OPENCLAW_REPO_DIR}/workspaces/telemetry/ /sandbox/.openclaw-data/agents/telemetry/agent/
+COPY ${OPENCLAW_REPO_DIR}/workspaces/backend/ /sandbox/.openclaw-data/agents/backend/agent/
+COPY ${OPENCLAW_REPO_DIR}/workspaces/db/ /sandbox/.openclaw-data/agents/db/agent/
+COPY ${OPENCLAW_REPO_DIR}/workspaces/verifier/ /sandbox/.openclaw-data/agents/verifier/agent/
+COPY ${OPENCLAW_REPO_DIR}/workspaces/comms/ /sandbox/.openclaw-data/agents/comms/agent/
+
+RUN chown -R sandbox:sandbox /sandbox/.openclaw-data/workspaces \
+    /sandbox/.openclaw-data/agents/sre \
+    /sandbox/.openclaw-data/agents/telemetry \
+    /sandbox/.openclaw-data/agents/backend \
+    /sandbox/.openclaw-data/agents/db \
+    /sandbox/.openclaw-data/agents/verifier \
+    /sandbox/.openclaw-data/agents/comms \
+    /sandbox/.openclaw-data/services/db_api
+
+RUN mkdir -p /sandbox/.openclaw-data/scripts/
+COPY ${OPENCLAW_REPO_DIR}/scripts/change-scenario.sh /sandbox/.openclaw-data/scripts/change-scenario.sh
+COPY ${OPENCLAW_REPO_DIR}/scripts/reset-sessions.sh /sandbox/.openclaw-data/scripts/reset-sessions.sh
+RUN chmod +x /sandbox/.openclaw-data/scripts/change-scenario.sh /sandbox/.openclaw-data/scripts/reset-sessions.sh
+
+ARG OPENCLAW_DEEP_OBS_DIR=observability-plugin
+COPY ${OPENCLAW_DEEP_OBS_DIR}/ /sandbox/.openclaw-data/plugins/observability/
+RUN cd /sandbox/.openclaw-data/plugins/observability && npm install --no-audit --no-fund --no-progress
+COPY ${OPENCLAW_DEEP_OBS_DIR}/openllmetry-patch-index.js /sandbox/.openclaw-data/plugins/observability/node_modules/@traceloop/instrumentation-openai/dist/index.js
+
