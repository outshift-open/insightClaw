+def build_sre_triage_agents_list() -> list[dict]:
+    """Build agents.list entries for SRE triage workspaces.
+
+    Generates entries that mirror sample-MAS/sre-triage/nemoclaw/list.json,
+    but uses sandbox paths baked into the NemoClaw image.
+    """
+    workspace_root = Path("/sandbox/.openclaw/workspaces")
+    agent_root = Path("/sandbox/.openclaw/agents")
+
+    workspace_ids = (
+        sorted(
+            d.name
+            for d in workspace_root.iterdir()
+            if d.is_dir() and not d.name.startswith(".")
+        )
+        if workspace_root.exists()
+        else []
+    )
+
+    if not workspace_ids:
+        workspace_ids = ["sre", "telemetry", "backend", "db", "verifier", "comms"]
+
+    allow_candidates = ["telemetry", "backend", "db", "debug", "debug_01", "debug_02"]
+    allow_agents = [aid for aid in allow_candidates if aid in workspace_ids]
+
+    special: dict[str, dict] = {
+        "sre": {
+            "name": "sre",
+            "identity": {"name": "sre"},
+            "subagents": {"allowAgents": allow_agents},
+            "tools": {"allow": ["sessions_spawn", "sessions_list", "sessions_send"]},
+        },
+        "telemetry": {
+            "name": "telemetry",
+            "identity": {"name": "telemetry"},
+            "tools": {
+                "allow": [
+                    "get_metrics",
+                    "list_services",
+                    "get_service_health",
+                    "get_logs",
+                    "query_db",
+                ]
+            },
+        },
+        "backend": {
+            "name": "backend",
+            "identity": {"name": "backend"},
+            "tools": {
+                "allow": [
+                    "get_deployments",
+                    "get_logs",
+                    "get_metrics",
+                    "run_action",
+                    "query_db",
+                ]
+            },
+        },
+        "db": {
+            "name": "db",
+            "identity": {"name": "db"},
+            "tools": {"allow": ["query_db"]},
+        },
+        "verifier": {
+            "name": "verifier",
+            "identity": {"name": "verifier"},
+        },
+        "comms": {
+            "name": "Communications",
+            "identity": {"name": "Communications"},
+        },
+    }
+
+    entries: list[dict] = []
+    for aid in workspace_ids:
+        entry: dict = {
+            "id": aid,
+            "workspace": str(workspace_root / aid),
+            "agentDir": str(agent_root / aid / "agent"),
+            "name": aid,
+            "identity": {"name": aid},
+        }
+        if aid in special:
+            entry.update(special[aid])
+        entries.append(entry)
+
+    if "sre" in workspace_ids:
+        entries.insert(
+            0,
+            {
+                "id": "main",
+                "workspace": str(workspace_root / "sre"),
+                "subagents": {"allowAgents": allow_agents},
+            },
+        )
+
+    return entries
+
