+cat > _OTLP_PROXY_SCRIPT <<'OTLP_PROXY_EOF'
+const http = require("http");
+const PROXY = { host: "10.200.0.1", port: 3128 };
+const TARGET = "http://2.13.195.139:4318"; // Otel collector endpoint
+
+const server = http.createServer((clientReq, clientRes) => {
+  const targetUrl = TARGET + clientReq.url;
+  const opts = {
+    hostname: PROXY.host,
+    port: PROXY.port,
+    path: targetUrl,
+    method: clientReq.method,
+    headers: { ...clientReq.headers, host: "2.13.195.139:4318" }
+  };
+  const proxyReq = http.request(opts, (proxyRes) => {
+    clientRes.writeHead(proxyRes.statusCode, proxyRes.headers);
+    proxyRes.pipe(clientRes);
+  });
+  proxyReq.on("error", (e) => {
+    clientRes.writeHead(502);
+    clientRes.end("proxy error: " + e.message);
+  });
+  clientReq.pipe(proxyReq);
+});
+server.listen(4318, "127.0.0.1", () => {
+  console.log("forwarder on 127.0.0.1:4318 -> " + TARGET + " via proxy");
+});
+OTLP_PROXY_EOF
+# Now, the OTLEL exporter can be configured to send to localhost:4318, and the above proxy will forward to the real collector endpoint.
