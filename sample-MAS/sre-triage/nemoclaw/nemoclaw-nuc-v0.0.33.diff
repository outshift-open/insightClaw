diff --git a/scripts/nemoclaw-start.sh b/scripts/nemoclaw-start.sh
index 1ce0f4c..8076b4f 100755
--- a/scripts/nemoclaw-start.sh
+++ b/scripts/nemoclaw-start.sh
@@ -198,6 +198,20 @@ fi
 PUBLIC_PORT="$_DASHBOARD_PORT"
 OPENCLAW="$(command -v openclaw)" # Resolve once, use absolute path everywhere
 _SANDBOX_HOME="/sandbox"          # Home dir for the sandbox user (useradd -d /sandbox in Dockerfile.base)
+DB_API_DIR="${_SANDBOX_HOME}/.openclaw/services/db_api"
+DB_API_PORT="${DB_API_PORT:-8765}"
+
+start_db_api() {
+  if [ ! -f "${DB_API_DIR}/app.py" ]; then
+    echo "[db-api] skipped: ${DB_API_DIR}/app.py not found" >&2
+    return 0
+  fi
+
+  nohup python3 -m uvicorn app:app --host 0.0.0.0 --port "${DB_API_PORT}" \
+    --app-dir "${DB_API_DIR}" >/tmp/db-api.log 2>&1 &
+  DB_API_PID=$!
+  echo "[db-api] launched on :${DB_API_PORT} (pid $DB_API_PID)" >&2
+}
 
